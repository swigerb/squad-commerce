@page "/"
@inject Services.ChatCommandService CommandService

<PageTitle>Squad Commerce - Dashboard</PageTitle>

<div class="dashboard-welcome">
    <div class="welcome-header">
        <h1>👋 Welcome to Squad Commerce</h1>
        <p class="lead">
            Your AI-powered retail management platform. Start a conversation in the left panel to analyze inventory, 
            pricing strategies, or competitive intelligence.
        </p>
    </div>

    <CommandCard Title="🚀 Try These Commands" CssClass="quick-actions-card">
        <div class="action-cards">
            <div class="action-card" @onclick='() => CommandService.SendCommand("Show me inventory levels for SKU-100 across all stores")' role="button" tabindex="0">
                <div class="action-icon">📦</div>
                <h3>Check Inventory</h3>
                <p>"Show me inventory levels for SKU-100 across all stores"</p>
                <span class="action-badge">Inventory Agent</span>
            </div>
            <div class="action-card" @onclick='() => CommandService.SendCommand("Calculate margin impact if we match competitor prices")' role="button" tabindex="0">
                <div class="action-icon">💰</div>
                <h3>Analyze Pricing</h3>
                <p>"Calculate margin impact if we match competitor prices"</p>
                <span class="action-badge">Pricing Agent</span>
            </div>
            <div class="action-card" @onclick='() => CommandService.SendCommand("Compare our prices with MegaMart for electronics")' role="button" tabindex="0">
                <div class="action-icon">📊</div>
                <h3>Compare Market</h3>
                <p>"Compare our prices with MegaMart for electronics"</p>
                <span class="action-badge">Market Intel Agent</span>
            </div>
        </div>
    </CommandCard>

    <div class="section-header">
        <h2>🩺 System Health</h2>
        <span class="section-status">● Live</span>
    </div>
    <TelemetryDashboard />

    <div class="section-header">
        <h2>🔗 Orchestration Pipeline</h2>
        <span class="section-status">● Live</span>
    </div>
    <PipelineNodeGraph />

    <div class="section-header">
        <h2>🧠 Agent Reasoning</h2>
        <span class="section-status">● Live</span>
    </div>
    <div class="reasoning-layout">
        <div class="reasoning-main">
            <ReasoningTracePanel />
        </div>
        <div class="reasoning-timeline">
            <ToolCallTimeline />
        </div>
    </div>

    <CommandCard Title="✨ What You Can Do" CssClass="features-card">
        <div class="feature-grid">
            <div class="feature-item">
                <div class="feature-icon">🔄</div>
                <div class="feature-text">
                    <h4>Real-Time Streaming</h4>
                    <p>Watch agents work in real-time with live status updates</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">📈</div>
                <div class="feature-text">
                    <h4>Interactive Visualizations</h4>
                    <p>Explore data with sortable tables, heatmaps, and charts</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">✅</div>
                <div class="feature-text">
                    <h4>Manager Approval</h4>
                    <p>Review and approve pricing changes with confidence</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🔗</div>
                <div class="feature-text">
                    <h4>A2A Integration</h4>
                    <p>Verified competitor data through agent-to-agent protocol</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🎯</div>
                <div class="feature-text">
                    <h4>MCP Tools</h4>
                    <p>Direct ERP integration via Model Context Protocol</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🎨</div>
                <div class="feature-text">
                    <h4>A2UI Components</h4>
                    <p>Native Blazor UI rendered from agent responses</p>
                </div>
            </div>
        </div>
    </CommandCard>

    <CommandCard CssClass="tech-stack-card">
        <h2>🛠️ Technology Stack</h2>
        <div class="tech-badges">
            <span class="tech-badge">Microsoft Agent Framework</span>
            <span class="tech-badge">Blazor Server</span>
            <span class="tech-badge">SignalR</span>
            <span class="tech-badge">AG-UI Protocol</span>
            <span class="tech-badge">A2UI Components</span>
            <span class="tech-badge">MCP Integration</span>
            <span class="tech-badge">A2A Handshake</span>
            <span class="tech-badge">OpenTelemetry</span>
        </div>
    </CommandCard>
</div>

<style>
    .dashboard-welcome {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .welcome-header {
        text-align: center;
        padding: 3rem 2rem;
        background: linear-gradient(135deg, rgba(88, 166, 255, 0.15) 0%, rgba(63, 185, 80, 0.08) 50%, rgba(188, 140, 255, 0.1) 100%);
        border: 1px solid rgba(88, 166, 255, 0.15);
        color: white;
        border-radius: 16px;
        position: relative;
        overflow: hidden;
    }

    .welcome-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 50%, rgba(88, 166, 255, 0.12), transparent 60%),
                    radial-gradient(ellipse at 70% 50%, rgba(63, 185, 80, 0.08), transparent 60%);
        z-index: 0;
    }

    .welcome-header > * {
        position: relative;
        z-index: 1;
    }

    .welcome-header h1 {
        margin: 0 0 1rem 0;
        font-size: 2.5rem;
        text-shadow: 0 0 40px rgba(88, 166, 255, 0.25);
    }

    .lead {
        font-size: 1.125rem;
        opacity: 0.85;
        max-width: 800px;
        margin: 0 auto;
        color: #8b949e;
    }

    .action-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .action-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 1.75rem;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s ease;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    .action-card::after {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.3s;
        border-radius: 14px;
    }

    .action-card:nth-child(1)::after {
        background: radial-gradient(circle at 50% 0%, rgba(88, 166, 255, 0.1), transparent 70%);
    }

    .action-card:nth-child(2)::after {
        background: radial-gradient(circle at 50% 0%, rgba(63, 185, 80, 0.1), transparent 70%);
    }

    .action-card:nth-child(3)::after {
        background: radial-gradient(circle at 50% 0%, rgba(188, 140, 255, 0.1), transparent 70%);
    }

    .action-card:hover {
        transform: translateY(-6px);
        border-color: rgba(88, 166, 255, 0.3);
        box-shadow: 0 8px 32px rgba(88, 166, 255, 0.12), 0 0 0 1px rgba(88, 166, 255, 0.1);
    }

    .action-card:hover::after {
        opacity: 1;
    }

    .action-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
    }

    .action-card h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.25rem;
        color: #e6edf3;
        position: relative;
        z-index: 1;
    }

    .action-card p {
        color: #8b949e;
        font-style: italic;
        margin-bottom: 1rem;
        font-size: 0.875rem;
        position: relative;
        z-index: 1;
    }

    .action-badge {
        display: inline-block;
        padding: 0.3rem 0.8rem;
        background: rgba(88, 166, 255, 0.1);
        border: 1px solid rgba(88, 166, 255, 0.25);
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
        color: #58a6ff;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        position: relative;
        z-index: 1;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
    }

    .feature-item {
        display: flex;
        align-items: start;
        gap: 1rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.25s;
    }

    .feature-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(88, 166, 255, 0.15);
        transform: translateX(4px);
    }

    .feature-icon {
        font-size: 2rem;
        flex-shrink: 0;
    }

    .feature-text h4 {
        margin: 0 0 0.5rem 0;
        font-size: 1rem;
        color: #e6edf3;
    }

    .feature-text p {
        margin: 0;
        font-size: 0.875rem;
        color: #8b949e;
    }

    .tech-stack-card {
        text-align: center;
    }

    .tech-stack-card h2 {
        margin: 0 0 1.5rem 0;
        color: #e6edf3;
    }

    .tech-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
    }

    .tech-badge {
        padding: 0.5rem 1rem;
        background: rgba(88, 166, 255, 0.06);
        border: 1px solid rgba(88, 166, 255, 0.2);
        color: #58a6ff;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.25s;
    }

    .tech-badge:hover {
        background: rgba(88, 166, 255, 0.12);
        border-color: rgba(88, 166, 255, 0.4);
        box-shadow: 0 0 12px rgba(88, 166, 255, 0.1);
        transform: translateY(-2px);
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 0.25rem;
    }

    .section-header h2 {
        margin: 0;
        font-size: 1.25rem;
        color: #e6edf3;
    }

    .section-status {
        font-size: 0.8rem;
        font-weight: 600;
        color: #3fb950;
        animation: status-pulse 2s infinite;
    }

    .reasoning-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .reasoning-main,
    .reasoning-timeline {
        min-width: 0;
    }

    @@media (max-width: 1024px) {
        .reasoning-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .welcome-header h1 {
            font-size: 1.75rem;
        }

        .action-cards {
            grid-template-columns: 1fr;
        }
    }

    @@keyframes status-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
</style>
