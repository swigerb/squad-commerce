@page "/"
@inject Services.ChatCommandService CommandService

<PageTitle>Squad Commerce - Dashboard</PageTitle>

<div class="dashboard-welcome">
    <div class="welcome-header">
        <h1>👋 Welcome to Squad Commerce</h1>
        <p class="lead">
            Your AI-powered retail management platform. Start a conversation in the left panel to analyze inventory, 
            pricing strategies, or competitive intelligence.
        </p>
    </div>

    <CommandCard Title="🚀 Try These Commands" CssClass="quick-actions-card">
        <div class="action-cards">
            <div class="action-card" @onclick='() => CommandService.SendCommand("Show me inventory levels for SKU-100 across all stores")' role="button" tabindex="0">
                <div class="action-icon">📦</div>
                <h3>Check Inventory</h3>
                <p>"Show me inventory levels for SKU-100 across all stores"</p>
                <span class="action-badge">Inventory Agent</span>
            </div>
            <div class="action-card" @onclick='() => CommandService.SendCommand("Calculate margin impact if we match competitor prices")' role="button" tabindex="0">
                <div class="action-icon">💰</div>
                <h3>Analyze Pricing</h3>
                <p>"Calculate margin impact if we match competitor prices"</p>
                <span class="action-badge">Pricing Agent</span>
            </div>
            <div class="action-card" @onclick='() => CommandService.SendCommand("Compare our prices with MegaMart for electronics")' role="button" tabindex="0">
                <div class="action-icon">📊</div>
                <h3>Compare Market</h3>
                <p>"Compare our prices with MegaMart for electronics"</p>
                <span class="action-badge">Market Intel Agent</span>
            </div>
        </div>
    </CommandCard>

    <CommandCard Title="✨ What You Can Do" CssClass="features-card">
        <div class="feature-grid">
            <div class="feature-item">
                <div class="feature-icon">🔄</div>
                <div class="feature-text">
                    <h4>Real-Time Streaming</h4>
                    <p>Watch agents work in real-time with live status updates</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">📈</div>
                <div class="feature-text">
                    <h4>Interactive Visualizations</h4>
                    <p>Explore data with sortable tables, heatmaps, and charts</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">✅</div>
                <div class="feature-text">
                    <h4>Manager Approval</h4>
                    <p>Review and approve pricing changes with confidence</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🔗</div>
                <div class="feature-text">
                    <h4>A2A Integration</h4>
                    <p>Verified competitor data through agent-to-agent protocol</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🎯</div>
                <div class="feature-text">
                    <h4>MCP Tools</h4>
                    <p>Direct ERP integration via Model Context Protocol</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🎨</div>
                <div class="feature-text">
                    <h4>A2UI Components</h4>
                    <p>Native Blazor UI rendered from agent responses</p>
                </div>
            </div>
        </div>
    </CommandCard>

    <CommandCard CssClass="tech-stack-card">
        <h2>🛠️ Technology Stack</h2>
        <div class="tech-badges">
            <span class="tech-badge">Microsoft Agent Framework</span>
            <span class="tech-badge">Blazor Server</span>
            <span class="tech-badge">SignalR</span>
            <span class="tech-badge">AG-UI Protocol</span>
            <span class="tech-badge">A2UI Components</span>
            <span class="tech-badge">MCP Integration</span>
            <span class="tech-badge">A2A Handshake</span>
            <span class="tech-badge">OpenTelemetry</span>
        </div>
    </CommandCard>
</div>

<style>
    .dashboard-welcome {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .welcome-header {
        text-align: center;
        padding: 2rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px;
    }

    .welcome-header h1 {
        margin: 0 0 1rem 0;
        font-size: 2.5rem;
    }

    .lead {
        font-size: 1.125rem;
        opacity: 0.95;
        max-width: 800px;
        margin: 0 auto;
    }

    .action-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .action-card {
        background: rgba(255, 255, 255, 0.04);
        padding: 1.5rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.2s;
        cursor: pointer;
    }

    .action-card:hover {
        transform: translateY(-4px);
        background: rgba(102, 126, 234, 0.1);
        border-color: rgba(102, 126, 234, 0.3);
        box-shadow: 0 4px 16px rgba(102, 126, 234, 0.15);
    }

    .action-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .action-card h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
    }

    .action-card p {
        color: rgba(255, 255, 255, 0.5);
        font-style: italic;
        margin-bottom: 1rem;
        font-size: 0.875rem;
    }

    .action-badge {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: rgba(102, 126, 234, 0.15);
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #667eea;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
    }

    .feature-item {
        display: flex;
        align-items: start;
        gap: 1rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        transition: all 0.2s;
    }

    .feature-item:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.12);
    }

    .feature-icon {
        font-size: 2rem;
        flex-shrink: 0;
    }

    .feature-text h4 {
        margin: 0 0 0.5rem 0;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.9);
    }

    .feature-text p {
        margin: 0;
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.5);
    }

    .tech-stack-card {
        text-align: center;
    }

    .tech-stack-card h2 {
        margin: 0 0 1.5rem 0;
        color: rgba(255, 255, 255, 0.9);
    }

    .tech-badges {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
    }

    .tech-badge {
        padding: 0.5rem 1rem;
        background: rgba(102, 126, 234, 0.08);
        border: 1px solid rgba(102, 126, 234, 0.3);
        color: #667eea;
        border-radius: 20px;
        font-size: 0.875rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .tech-badge:hover {
        background: rgba(102, 126, 234, 0.15);
        border-color: rgba(102, 126, 234, 0.5);
    }
</style>
