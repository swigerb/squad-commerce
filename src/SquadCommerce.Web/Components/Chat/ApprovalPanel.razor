@inject HttpClient Http

<div class="approval-panel @_state" role="region" aria-label="Approval Panel">
    @if (_state == "hidden")
    {
        return;
    }

    <CommandCard CssClass="approval-card">
        <div class="approval-header">
            <FluentLabel Weight="FontWeight.Bold" Style="font-size: 1.1rem; color: rgba(255,255,255,0.95);">📋 Manager Approval Required</FluentLabel>
            <FluentButton Appearance="Appearance.Stealth" OnClick="Dismiss" aria-label="Dismiss approval panel"
                          IconStart="@(new Icons.Regular.Size16.Dismiss())" />
        </div>

        <FluentCard Class="approval-summary-card">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" Style="width: 100%;">
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem;">
                    <FluentLabel Style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">Total Changes</FluentLabel>
                    <FluentLabel Weight="FontWeight.Bold" Style="font-size: 1.5rem; color: rgba(255,255,255,0.95);">@_totalChanges</FluentLabel>
                </FluentStack>
                <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.End" Style="gap: 0.25rem;">
                    <FluentLabel Style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">Estimated Impact</FluentLabel>
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem;">
                        <FluentLabel Weight="FontWeight.Bold" Style="font-size: 1.5rem; color: rgba(255,255,255,0.95);">@_estimatedImpact.ToString("C0")</FluentLabel>
                        <FluentBadge Appearance="@GetRiskBadgeAppearance()" Class="@($"risk-badge {GetRiskCssClass()}")">@GetRiskLabel()</FluentBadge>
                    </FluentStack>
                </FluentStack>
            </FluentStack>
        </FluentCard>

        @if (_editMode)
        {
            <FluentCard Class="approval-edit-card">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem; margin-bottom: 0.5rem;">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Edit())" Color="Color.Accent" />
                    <FluentLabel Weight="FontWeight.Bold" Style="color: rgba(255,255,255,0.9);">Edit Mode</FluentLabel>
                </FluentStack>
                <FluentLabel Style="color: rgba(255,255,255,0.5); font-size: 0.875rem;">Custom edits will be available in a future update.</FluentLabel>
            </FluentCard>
        }

        <div class="approval-actions">
            @if (!_processing)
            {
                <FluentButton Appearance="Appearance.Accent" OnClick="ApproveAll"
                              aria-label="Approve all changes"
                              IconStart="@(new Icons.Regular.Size20.CheckmarkCircle())"
                              Class="approval-btn-fluent">
                    Approve All
                </FluentButton>

                <FluentButton Appearance="Appearance.Outline" OnClick="ToggleEditMode"
                              aria-label="Modify changes"
                              IconStart="@(new Icons.Regular.Size20.Edit())"
                              Class="approval-btn-fluent">
                    @(_editMode ? "Cancel Edit" : "Modify")
                </FluentButton>

                <FluentButton Appearance="Appearance.Outline" OnClick="RejectAll"
                              aria-label="Reject all changes"
                              IconStart="@(new Icons.Regular.Size20.DismissCircle())"
                              Class="approval-btn-fluent reject-btn">
                    Reject All
                </FluentButton>
            }
            else
            {
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem; justify-content: center; padding: 0.5rem 0;">
                    <FluentProgress />
                    <FluentLabel Style="color: rgba(255,255,255,0.7);">Processing your decision...</FluentLabel>
                </FluentStack>
            }
        </div>

        @if (!string.IsNullOrEmpty(_resultMessage))
        {
            <FluentCard Class="@($"approval-result {_resultClass}")" role="alert">
                <FluentLabel Style="color: inherit;">@_resultMessage</FluentLabel>
            </FluentCard>
        }
    </CommandCard>

    @if (_showConfirmDialog)
    {
        <div class="approval-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="confirm-dialog-title">
            <div class="confirm-dialog-overlay" @onclick="CancelConfirm"></div>
            <CommandCard CssClass="confirm-dialog-card">
                <FluentLabel Weight="FontWeight.Bold" Style="font-size: 1.1rem; color: rgba(255,255,255,0.95); margin-bottom: 0.75rem;">⚠️ Confirm Your Decision</FluentLabel>
                <FluentLabel Style="color: rgba(255,255,255,0.7); margin-bottom: 1.25rem; display: block;">@_confirmMessage</FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.75rem;">
                    <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmAction">
                        Yes, I'm sure
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Outline" OnClick="CancelConfirm">
                        Cancel
                    </FluentButton>
                </FluentStack>
            </CommandCard>
        </div>
    }
</div>

@code {
    [Parameter]
    public int TotalChanges { get; set; }

    [Parameter]
    public decimal EstimatedImpact { get; set; }

    [Parameter]
    public EventCallback OnApproved { get; set; }

    [Parameter]
    public EventCallback OnRejected { get; set; }

    private string _state = "hidden"; // hidden, visible, processing
    private int _totalChanges;
    private decimal _estimatedImpact;
    private bool _editMode = false;
    private bool _processing = false;
    private bool _showConfirmDialog = false;
    private string _confirmMessage = string.Empty;
    private string _resultMessage = string.Empty;
    private string _resultClass = string.Empty;
    private Action? _pendingAction;

    protected override void OnParametersSet()
    {
        _totalChanges = TotalChanges;
        _estimatedImpact = EstimatedImpact;

        if (_totalChanges > 0)
        {
            _state = "visible";
        }
    }

    public void Show(int changes, decimal impact)
    {
        _totalChanges = changes;
        _estimatedImpact = impact;
        _state = "visible";
        StateHasChanged();
    }

    public void Hide()
    {
        _state = "hidden";
        StateHasChanged();
    }

    private void Dismiss()
    {
        _state = "hidden";
    }

    private void ToggleEditMode()
    {
        _editMode = !_editMode;
    }

    private void ApproveAll()
    {
        _confirmMessage = $"Are you sure you want to approve {_totalChanges} change(s)? This will update pricing across affected stores.";
        _pendingAction = async () => await ExecuteApproval();
        _showConfirmDialog = true;
    }

    private void RejectAll()
    {
        _confirmMessage = $"Are you sure you want to reject {_totalChanges} change(s)? No changes will be made.";
        _pendingAction = async () => await ExecuteRejection();
        _showConfirmDialog = true;
    }

    private async Task ConfirmAction()
    {
        _showConfirmDialog = false;
        if (_pendingAction != null)
        {
            _pendingAction();
            _pendingAction = null;
        }
    }

    private void CancelConfirm()
    {
        _showConfirmDialog = false;
        _pendingAction = null;
    }

    private async Task ExecuteApproval()
    {
        _processing = true;
        _resultMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            // POST to /api/pricing/approve
            var response = await Http.PostAsJsonAsync("/api/pricing/approve", new
            {
                Changes = _totalChanges,
                Impact = _estimatedImpact
            });

            if (response.IsSuccessStatusCode)
            {
                _resultMessage = "✅ Changes approved successfully!";
                _resultClass = "alert-success";
                
                if (OnApproved.HasDelegate)
                {
                    await OnApproved.InvokeAsync();
                }

                await Task.Delay(2000);
                _state = "hidden";
            }
            else
            {
                _resultMessage = $"❌ Approval failed: {response.ReasonPhrase}";
                _resultClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            _resultMessage = $"❌ Error: {ex.Message}";
            _resultClass = "alert-danger";
        }
        finally
        {
            _processing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExecuteRejection()
    {
        _processing = true;
        _resultMessage = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            // POST to /api/pricing/reject
            var response = await Http.PostAsJsonAsync("/api/pricing/reject", new
            {
                Changes = _totalChanges,
                Reason = "Manager rejected"
            });

            if (response.IsSuccessStatusCode)
            {
                _resultMessage = "Changes rejected. No updates were made.";
                _resultClass = "alert-info";
                
                if (OnRejected.HasDelegate)
                {
                    await OnRejected.InvokeAsync();
                }

                await Task.Delay(2000);
                _state = "hidden";
            }
            else
            {
                _resultMessage = $"❌ Rejection failed: {response.ReasonPhrase}";
                _resultClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            _resultMessage = $"❌ Error: {ex.Message}";
            _resultClass = "alert-danger";
        }
        finally
        {
            _processing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetImpactClass()
    {
        if (_estimatedImpact < 0)
            return "text-danger";
        if (_estimatedImpact > 0)
            return "text-success";
        return "text-muted";
    }

    private double GetMarginImpactPercent()
    {
        if (_totalChanges == 0) return 0;
        return (double)Math.Abs(_estimatedImpact) / Math.Max(_totalChanges * 100, 1) * 100;
    }

    private string GetRiskLabel()
    {
        var pct = GetMarginImpactPercent();
        if (pct <= 5) return "Low Risk";
        if (pct <= 15) return "Medium Risk";
        return "High Risk";
    }

    private string GetRiskCssClass()
    {
        var pct = GetMarginImpactPercent();
        if (pct <= 5) return "risk-low";
        if (pct <= 15) return "risk-medium";
        return "risk-high";
    }

    private Appearance GetRiskBadgeAppearance()
    {
        return Appearance.Neutral;
    }
}
