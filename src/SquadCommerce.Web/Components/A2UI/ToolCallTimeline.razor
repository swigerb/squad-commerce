@* ToolCallTimeline.razor — Horizontal Gantt-style timeline for MCP tool calls and A2A handshakes *@
@using SquadCommerce.Contracts
@implements IDisposable
@inject Services.SignalRStateService SignalR

<CommandCard Title="⚡ Tool Call Timeline" CssClass="tool-timeline-panel">
    <div class="timeline-controls">
        <div class="timeline-legend">
            <span class="legend-item">
                <span class="legend-swatch legend-tool"></span> Tool Call
            </span>
            <span class="legend-item">
                <span class="legend-swatch legend-a2a"></span> A2A Handshake
            </span>
        </div>
        <span class="timeline-count">@_toolSteps.Count calls</span>
    </div>

    @if (_toolSteps.Count == 0)
    {
        <div class="timeline-empty">
            <div class="timeline-empty-icon">⚡</div>
            <p>No tool calls or A2A handshakes yet.</p>
        </div>
    }
    else
    {
        <div class="timeline-chart" role="img" aria-label="Tool call timeline showing duration of each call by agent">
            @foreach (var agentGroup in _toolSteps.GroupBy(s => s.AgentName))
            {
                var agentColor = GetAgentColor(agentGroup.Key);

                <div class="timeline-row">
                    <div class="timeline-agent-label" title="@agentGroup.Key" style="color: @agentColor;">
                        @agentGroup.Key
                    </div>
                    <div class="timeline-bars-container">
                        <div class="timeline-bars" style="width: @(GetTimelineWidth())px;">
                            @foreach (var step in agentGroup)
                            {
                                var barClass = step.StepType == ReasoningStepType.ToolCall ? "bar-tool" : "bar-a2a";
                                var leftPx = GetBarLeft(step);
                                var widthPx = GetBarWidth(step);
                                var toolName = step.Metadata?.GetValueOrDefault("ToolName") ?? step.Content;
                                var displayName = toolName.Length > 30 ? toolName[..27] + "…" : toolName;

                                <div class="timeline-bar @barClass bar-enter"
                                     style="left: @(leftPx)px; width: @(widthPx)px;"
                                     title="@toolName — @FormatDuration(step.DurationMs)"
                                     role="listitem"
                                     aria-label="@step.StepType: @toolName, duration @FormatDuration(step.DurationMs)">
                                    <span class="bar-label">@displayName</span>
                                    @if (step.DurationMs > 0)
                                    {
                                        <span class="bar-duration">@FormatDuration(step.DurationMs)</span>
                                    }
                                    <div class="bar-tooltip">
                                        <div class="tooltip-type">@step.StepType</div>
                                        <div class="tooltip-name">@toolName</div>
                                        <div class="tooltip-duration">Duration: @FormatDuration(step.DurationMs)</div>
                                        <div class="tooltip-time">@step.Timestamp.ToString("HH:mm:ss.fff")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</CommandCard>

@code {
    private readonly List<ReasoningStep> _toolSteps = new();
    private string? _currentSessionId;
    private DateTimeOffset _timelineStart;
    private long _timelineMaxMs = 1000; // minimum 1s width

    private static readonly string[] AgentColors = [
        "#667eea", "#10b981", "#f59e0b", "#ef4444",
        "#8b5cf6", "#06b6d4", "#ec4899", "#14b8a6",
    ];
    private readonly Dictionary<string, string> _agentColorMap = new();

    protected override void OnInitialized()
    {
        SignalR.OnReasoningStep += HandleReasoningStep;
    }

    private async void HandleReasoningStep(ReasoningStep step)
    {
        // Only track ToolCall and A2AHandshake
        if (step.StepType != ReasoningStepType.ToolCall && step.StepType != ReasoningStepType.A2AHandshake)
            return;

        // Clear on new session
        if (_currentSessionId != null && _currentSessionId != step.SessionId)
        {
            _toolSteps.Clear();
            _agentColorMap.Clear();
        }
        _currentSessionId = step.SessionId;

        if (_toolSteps.Count == 0)
            _timelineStart = step.Timestamp;

        _toolSteps.Add(step);
        RecalculateTimeline();

        await InvokeAsync(StateHasChanged);
    }

    private void RecalculateTimeline()
    {
        if (_toolSteps.Count == 0) return;

        var lastStep = _toolSteps[^1];
        var endMs = (long)(lastStep.Timestamp - _timelineStart).TotalMilliseconds + Math.Max(lastStep.DurationMs, 100);
        _timelineMaxMs = Math.Max(endMs, 1000);
    }

    private double GetBarLeft(ReasoningStep step)
    {
        var offsetMs = (step.Timestamp - _timelineStart).TotalMilliseconds;
        return Math.Max(0, offsetMs / _timelineMaxMs * GetTimelineWidth());
    }

    private double GetBarWidth(ReasoningStep step)
    {
        var durationMs = Math.Max(step.DurationMs, 80); // minimum visible width
        return Math.Max(60, durationMs / (double)_timelineMaxMs * GetTimelineWidth());
    }

    private double GetTimelineWidth()
    {
        // Base width scales with number of events; minimum 600px
        return Math.Max(600, _toolSteps.Count * 150);
    }

    private string GetAgentColor(string agentName)
    {
        if (!_agentColorMap.TryGetValue(agentName, out var color))
        {
            color = AgentColors[_agentColorMap.Count % AgentColors.Length];
            _agentColorMap[agentName] = color;
        }
        return color;
    }

    private static string FormatDuration(long ms) => ms switch
    {
        < 1000 => $"{ms}ms",
        < 60_000 => $"{ms / 1000.0:F1}s",
        _ => $"{ms / 60_000.0:F1}m"
    };

    public void Dispose()
    {
        SignalR.OnReasoningStep -= HandleReasoningStep;
    }
}

<style>
    .tool-timeline-panel {
        overflow: hidden;
    }

    .timeline-controls {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .timeline-legend {
        display: flex;
        gap: 1rem;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 600;
    }

    .legend-swatch {
        width: 12px;
        height: 12px;
        border-radius: 3px;
    }

    .legend-tool {
        background: rgba(16, 185, 129, 0.6);
        border: 1px solid #10b981;
    }

    .legend-a2a {
        background: rgba(59, 130, 246, 0.6);
        border: 1px solid #3b82f6;
    }

    .timeline-count {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 600;
    }

    .timeline-empty {
        text-align: center;
        padding: 2rem 1rem;
        color: rgba(255, 255, 255, 0.4);
    }

    .timeline-empty-icon {
        font-size: 2.5rem;
        margin-bottom: 0.75rem;
        opacity: 0.5;
    }

    .timeline-empty p {
        margin: 0;
        font-size: 0.85rem;
    }

    .timeline-chart {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .timeline-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        min-height: 36px;
    }

    .timeline-agent-label {
        width: 100px;
        flex-shrink: 0;
        font-size: 0.75rem;
        font-weight: 700;
        text-align: right;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .timeline-bars-container {
        flex: 1;
        overflow-x: auto;
        overflow-y: hidden;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 6px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 4px 0;
    }

    /* Auto-scroll to right for new events */
    .timeline-bars-container {
        scroll-behavior: smooth;
        direction: ltr;
    }

    .timeline-bars-container::-webkit-scrollbar {
        height: 4px;
    }

    .timeline-bars-container::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.02);
    }

    .timeline-bars-container::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.12);
        border-radius: 2px;
    }

    .timeline-bars {
        position: relative;
        height: 28px;
        min-width: 100%;
    }

    .timeline-bar {
        position: absolute;
        top: 2px;
        height: 24px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 0.5rem;
        gap: 0.35rem;
        cursor: default;
        transition: filter 0.15s;
        overflow: hidden;
        white-space: nowrap;
    }

    .timeline-bar:hover {
        filter: brightness(1.3);
        z-index: 10;
    }

    .timeline-bar:hover .bar-tooltip {
        display: block;
    }

    .bar-tool {
        background: rgba(16, 185, 129, 0.25);
        border: 1px solid rgba(16, 185, 129, 0.5);
    }

    .bar-a2a {
        background: rgba(59, 130, 246, 0.25);
        border: 1px solid rgba(59, 130, 246, 0.5);
    }

    .bar-enter {
        animation: barSlideIn 0.3s ease-out;
    }

    @@keyframes barSlideIn {
        from {
            opacity: 0;
            transform: scaleX(0);
            transform-origin: left;
        }
        to {
            opacity: 1;
            transform: scaleX(1);
        }
    }

    .bar-label {
        font-size: 0.65rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .bar-duration {
        font-size: 0.6rem;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.6);
        font-family: 'Cascadia Code', 'Fira Code', monospace;
        flex-shrink: 0;
    }

    .bar-tooltip {
        display: none;
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        background: rgba(30, 35, 45, 0.97);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        padding: 0.6rem 0.8rem;
        z-index: 100;
        min-width: 180px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
    }

    .tooltip-type {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 0.25rem;
    }

    .tooltip-name {
        font-size: 0.8rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.9);
        margin-bottom: 0.35rem;
        word-break: break-word;
        white-space: normal;
    }

    .tooltip-duration {
        font-size: 0.75rem;
        color: #10b981;
        font-weight: 600;
    }

    .tooltip-time {
        font-size: 0.65rem;
        color: rgba(255, 255, 255, 0.4);
        font-family: 'Cascadia Code', 'Fira Code', monospace;
        margin-top: 0.15rem;
    }
</style>
