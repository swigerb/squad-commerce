@using SquadCommerce.Contracts.A2UI
@using System.Text.Json

<div class="market-wrapper" role="region" aria-label="Market Comparison">
    @if (_data != null)
    {
        <div class="market-title-bar">
            <h3 class="market-title">🔍 Market Intelligence — <span class="product-accent">@_data.ProductName</span></h3>
            <span class="market-ts">@_data.Timestamp.ToString("g")</span>
        </div>

        <div class="our-price-hero">
            <span class="our-label">Our Price</span>
            <span class="our-amount">@_data.OurPrice.ToString("C")</span>
            <span class="our-sku">@_data.Sku</span>
        </div>

        @if (_data.Competitors != null && _data.Competitors.Any())
        {
            <div class="competitor-list">
                @{ var cIdx = 0; }
                @foreach (var comp in GetSortedCompetitors())
                {
                    var delta = CalculateDelta(comp.Price);
                    var deltaPct = CalculateDeltaPercent(comp.Price);
                    var color = GetCompetitorColor(cIdx);
                    <div class="competitor-card" style="animation-delay: @(cIdx * 0.08)s"
                         role="article" aria-label="@comp.CompetitorName: @comp.Price.ToString("C")">
                        <div class="comp-left">
                            <div class="comp-avatar" style="background: @color">
                                @GetInitial(comp.CompetitorName)
                            </div>
                            <div class="comp-info">
                                <div class="comp-name-row">
                                    <span class="comp-name">@comp.CompetitorName</span>
                                    @if (comp.Verified)
                                    {
                                        <span class="verify-badge verified">✅ Verified</span>
                                    }
                                    else
                                    {
                                        <span class="verify-badge unverified">⚠️ Unverified</span>
                                    }
                                </div>
                                <div class="comp-meta">
                                    <span class="source-badge">
                                        <span class="source-dot"></span>
                                        @TruncateSource(comp.Source)
                                    </span>
                                    <span class="updated-text">@GetRelativeTime(comp.LastUpdated)</span>
                                </div>
                            </div>
                        </div>
                        <div class="comp-right">
                            <div class="comp-price">@comp.Price.ToString("C")</div>
                            @if (delta > 0)
                            {
                                <span class="delta-pill pill-green" title="Our advantage">
                                    We're @Math.Abs(delta).ToString("C") cheaper
                                </span>
                            }
                            else if (delta < 0)
                            {
                                <span class="delta-pill pill-red" title="Competitor advantage">
                                    They're @Math.Abs(delta).ToString("C") cheaper
                                </span>
                            }
                            else
                            {
                                <span class="delta-pill pill-yellow" title="Equal pricing">
                                    Same price
                                </span>
                            }
                        </div>
                        <div class="confidence-row">
                            <span class="conf-label">Confidence</span>
                            <div class="conf-track">
                                <div class="conf-fill @GetConfidenceClass(comp)"
                                     style="width: @GetConfidencePercent(comp)%; animation-delay: @(cIdx * 0.08 + 0.3)s"></div>
                            </div>
                            <span class="conf-level">@GetConfidenceLabel(comp)</span>
                        </div>
                    </div>
                    cIdx++;
                }
            </div>

            <div class="market-summary">
                <div class="summary-card rank-card">
                    <span class="summary-icon">🏆</span>
                    <span class="summary-val">@GetRankText()</span>
                    <span class="summary-label">Our Position</span>
                </div>
                <div class="summary-card">
                    <span class="summary-icon">📊</span>
                    <span class="summary-val">@GetAveragePrice().ToString("C")</span>
                    <span class="summary-label">Market Average</span>
                </div>
                <div class="summary-card insight-card">
                    <span class="summary-icon">💡</span>
                    <span class="summary-val insight-text">@GetMarketInsight()</span>
                    <span class="summary-label">Market Opportunity</span>
                </div>
            </div>
        }
        else
        {
            <div class="no-data">No competitor data available</div>
        }
    }
    else
    {
        <div class="no-data">Loading market data…</div>
    }
</div>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }

    private MarketComparisonGridData? _data;
    private string? _sortColumn;
    private bool _sortAscending = true;

    private static readonly string[] CompetitorColors =
        ["#f85149", "#d29922", "#58a6ff", "#bc8cff", "#3fb950", "#ff7b72", "#79c0ff", "#ffa657"];

    protected override void OnParametersSet()
    {
        if (Payload?.Data != null)
        {
            if (Payload.Data is JsonElement jsonElement)
            {
                _data = JsonSerializer.Deserialize<MarketComparisonGridData>(
                    jsonElement.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else if (Payload.Data is MarketComparisonGridData typedData)
            {
                _data = typedData;
            }
        }
    }

    private IEnumerable<CompetitorPrice> GetSortedCompetitors()
    {
        if (_data?.Competitors == null)
            return Enumerable.Empty<CompetitorPrice>();

        var competitors = _data.Competitors.AsEnumerable();

        if (_sortColumn != null)
        {
            competitors = _sortColumn switch
            {
                nameof(CompetitorPrice.CompetitorName) => _sortAscending
                    ? competitors.OrderBy(c => c.CompetitorName)
                    : competitors.OrderByDescending(c => c.CompetitorName),
                nameof(CompetitorPrice.Price) => _sortAscending
                    ? competitors.OrderBy(c => c.Price)
                    : competitors.OrderByDescending(c => c.Price),
                nameof(CompetitorPrice.LastUpdated) => _sortAscending
                    ? competitors.OrderBy(c => c.LastUpdated)
                    : competitors.OrderByDescending(c => c.LastUpdated),
                _ => competitors
            };
        }

        return competitors;
    }

    private decimal CalculateDelta(decimal competitorPrice) =>
        competitorPrice - (_data?.OurPrice ?? 0);

    private decimal CalculateDeltaPercent(decimal competitorPrice)
    {
        if (_data?.OurPrice == 0 || _data == null) return 0;
        return (competitorPrice - _data.OurPrice) / _data.OurPrice;
    }

    private string TruncateSource(string source) =>
        source.Length > 30 ? source.Substring(0, 27) + "..." : source;

    private string GetRelativeTime(DateTimeOffset lastUpdated)
    {
        var diff = DateTimeOffset.Now - lastUpdated;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    private char GetInitial(string name) =>
        string.IsNullOrEmpty(name) ? '?' : char.ToUpper(name[0]);

    private string GetCompetitorColor(int index) =>
        CompetitorColors[index % CompetitorColors.Length];

    private decimal GetAveragePrice()
    {
        if (_data?.Competitors == null || !_data.Competitors.Any()) return 0;
        return _data.Competitors.Average(c => c.Price);
    }

    private string GetRankText()
    {
        if (_data?.Competitors == null || !_data.Competitors.Any()) return "N/A";
        var allPrices = _data.Competitors.Select(c => c.Price).Append(_data.OurPrice).OrderBy(p => p).ToList();
        var rank = allPrices.IndexOf(_data.OurPrice) + 1;
        return $"#{rank} of {allPrices.Count}";
    }

    private string GetConfidenceClass(CompetitorPrice comp)
    {
        if (comp.Verified && (DateTimeOffset.Now - comp.LastUpdated).TotalHours < 24) return "conf-high";
        if (comp.Verified) return "conf-medium";
        return "conf-low";
    }

    private int GetConfidencePercent(CompetitorPrice comp)
    {
        if (comp.Verified && (DateTimeOffset.Now - comp.LastUpdated).TotalHours < 24) return 95;
        if (comp.Verified) return 70;
        return 40;
    }

    private string GetConfidenceLabel(CompetitorPrice comp)
    {
        if (comp.Verified && (DateTimeOffset.Now - comp.LastUpdated).TotalHours < 24) return "High";
        if (comp.Verified) return "Medium";
        return "Low";
    }

    private string GetMarketInsight()
    {
        if (_data == null) return "Insufficient data";
        var avg = GetAveragePrice();
        if (_data.OurPrice < avg * 0.9m)
            return "Strong competitive position — consider selective price increases";
        if (_data.OurPrice > avg * 1.1m)
            return "Premium positioning — monitor for volume impact";
        return "Aligned with market — differentiate on value";
    }
}
