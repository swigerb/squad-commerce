@using SquadCommerce.Contracts.A2UI
@using System.Text.Json

<CommandCard>
<div class="market-comparison-grid" role="region" aria-label="Market Comparison Grid">
    <div class="component-header">
        <h3>📊 Competitive Price Comparison</h3>
        @if (_data != null)
        {
            <div class="timestamp">
                <span class="timestamp-label">Product:</span>
                <span class="timestamp-value">@_data.ProductName (@_data.Sku)</span>
                <span class="timestamp-label ms-3">Our Price:</span>
                <span class="our-price-badge">@_data.OurPrice.ToString("C")</span>
                <span class="timestamp-label ms-3">Updated:</span>
                <span class="timestamp-value">@_data.Timestamp.ToString("g")</span>
            </div>
        }
    </div>

    @if (_data?.Competitors != null && _data.Competitors.Any())
    {
        <div class="comparison-table-container">
            <table class="table table-hover comparison-table" aria-label="Competitor price comparison">
                <thead>
                    <tr>
                        <th scope="col" class="sortable" @onclick="() => SortBy(nameof(CompetitorPrice.CompetitorName))">
                            Competitor @GetSortIndicator(nameof(CompetitorPrice.CompetitorName))
                        </th>
                        <th scope="col" class="sortable numeric-col" @onclick="() => SortBy(nameof(CompetitorPrice.Price))">
                            Their Price @GetSortIndicator(nameof(CompetitorPrice.Price))
                        </th>
                        <th scope="col" class="numeric-col">Delta from Ours</th>
                        <th scope="col" class="status-col">Verification</th>
                        <th scope="col" class="source-col">Source</th>
                        <th scope="col" class="sortable" @onclick="() => SortBy(nameof(CompetitorPrice.LastUpdated))">
                            Last Updated @GetSortIndicator(nameof(CompetitorPrice.LastUpdated))
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var competitor in GetSortedCompetitors())
                    {
                        var delta = CalculateDelta(competitor.Price);
                        var deltaPercent = CalculateDeltaPercent(competitor.Price);
                        <tr class="@GetRowCssClass(competitor)">
                            <th scope="row">@competitor.CompetitorName</th>
                            <td class="numeric-col price-cell">@competitor.Price.ToString("C")</td>
                            <td class="numeric-col delta-cell">
                                @if (delta > 0)
                                {
                                    <FluentBadge Class="delta-badge delta-badge-positive" title="Our advantage: competitor is more expensive">
                                        ▲ @delta.ToString("+$0.00;-$0.00;$0.00") (@deltaPercent.ToString("+0.0%;-0.0%;0.0%"))
                                    </FluentBadge>
                                }
                                else if (delta < 0)
                                {
                                    <FluentBadge Class="delta-badge delta-badge-negative" title="Competitor advantage: competitor is cheaper">
                                        ▼ @delta.ToString("+$0.00;-$0.00;$0.00") (@deltaPercent.ToString("+0.0%;-0.0%;0.0%"))
                                    </FluentBadge>
                                }
                                else
                                {
                                    <FluentBadge Class="delta-badge delta-badge-neutral" title="Equal pricing">
                                        – $0.00 (0.0%)
                                    </FluentBadge>
                                }
                            </td>
                            <td class="status-col">
                                @if (competitor.Verified)
                                {
                                    <span class="verification-badge verified" aria-label="Verified via A2A">
                                        ✅ Verified
                                    </span>
                                }
                                else
                                {
                                    <span class="verification-badge unverified" aria-label="Unverified">
                                        ⚠️ Unverified
                                    </span>
                                }
                            </td>
                            <td class="source-col" title="@competitor.Source">
                                @TruncateSource(competitor.Source)
                            </td>
                            <td class="updated-col">
                                @GetRelativeTime(competitor.LastUpdated)
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="comparison-summary">
            <div class="summary-card">
                <div class="summary-label">Lowest Competitor Price</div>
                <div class="summary-value">@GetLowestPrice().ToString("C")</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Highest Competitor Price</div>
                <div class="summary-value">@GetHighestPrice().ToString("C")</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Average Competitor Price</div>
                <div class="summary-value">@GetAveragePrice().ToString("C")</div>
            </div>
            <div class="summary-card @GetPositionCssClass()">
                <div class="summary-label">Our Position</div>
                <div class="summary-value">@GetOurPosition()</div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">No competitor data available</div>
    }
</div>
</CommandCard>

<style>
    .delta-badge {
        font-weight: 600;
        font-size: 0.85rem;
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
        display: inline-block;
    }

    .delta-badge-positive {
        background: rgba(16, 185, 129, 0.15) !important;
        color: #10b981 !important;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }

    .delta-badge-negative {
        background: rgba(239, 68, 68, 0.15) !important;
        color: #ef4444 !important;
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .delta-badge-neutral {
        background: rgba(107, 114, 128, 0.15) !important;
        color: #9ca3af !important;
        border: 1px solid rgba(107, 114, 128, 0.3);
    }
</style>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }

    private MarketComparisonGridData? _data;
    private string? _sortColumn;
    private bool _sortAscending = true;

    protected override void OnParametersSet()
    {
        if (Payload?.Data != null)
        {
            if (Payload.Data is JsonElement jsonElement)
            {
                _data = JsonSerializer.Deserialize<MarketComparisonGridData>(
                    jsonElement.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else if (Payload.Data is MarketComparisonGridData typedData)
            {
                _data = typedData;
            }
        }
    }

    private IEnumerable<CompetitorPrice> GetSortedCompetitors()
    {
        if (_data?.Competitors == null)
            return Enumerable.Empty<CompetitorPrice>();

        var competitors = _data.Competitors.AsEnumerable();

        if (_sortColumn != null)
        {
            competitors = _sortColumn switch
            {
                nameof(CompetitorPrice.CompetitorName) => _sortAscending
                    ? competitors.OrderBy(c => c.CompetitorName)
                    : competitors.OrderByDescending(c => c.CompetitorName),
                nameof(CompetitorPrice.Price) => _sortAscending
                    ? competitors.OrderBy(c => c.Price)
                    : competitors.OrderByDescending(c => c.Price),
                nameof(CompetitorPrice.LastUpdated) => _sortAscending
                    ? competitors.OrderBy(c => c.LastUpdated)
                    : competitors.OrderByDescending(c => c.LastUpdated),
                _ => competitors
            };
        }

        return competitors;
    }

    private void SortBy(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private string GetSortIndicator(string column)
    {
        if (_sortColumn != column)
            return "⇅";
        return _sortAscending ? "↑" : "↓";
    }

    private decimal CalculateDelta(decimal competitorPrice)
    {
        return competitorPrice - (_data?.OurPrice ?? 0);
    }

    private decimal CalculateDeltaPercent(decimal competitorPrice)
    {
        if (_data?.OurPrice == 0 || _data == null)
            return 0;
        return (competitorPrice - _data.OurPrice) / _data.OurPrice;
    }

    private string GetDeltaCssClass(decimal delta)
    {
        if (delta < 0) return "delta-negative"; // They're cheaper
        if (delta > 0) return "delta-positive"; // We're cheaper
        return "delta-neutral";
    }

    private string GetRowCssClass(CompetitorPrice competitor)
    {
        if (!competitor.Verified)
            return "row-unverified";
        return string.Empty;
    }

    private string TruncateSource(string source)
    {
        if (source.Length > 30)
            return source.Substring(0, 27) + "...";
        return source;
    }

    private string GetRelativeTime(DateTimeOffset lastUpdated)
    {
        var diff = DateTimeOffset.Now - lastUpdated;
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }

    private decimal GetLowestPrice()
    {
        if (_data?.Competitors == null || !_data.Competitors.Any())
            return 0;
        return _data.Competitors.Min(c => c.Price);
    }

    private decimal GetHighestPrice()
    {
        if (_data?.Competitors == null || !_data.Competitors.Any())
            return 0;
        return _data.Competitors.Max(c => c.Price);
    }

    private decimal GetAveragePrice()
    {
        if (_data?.Competitors == null || !_data.Competitors.Any())
            return 0;
        return _data.Competitors.Average(c => c.Price);
    }

    private string GetOurPosition()
    {
        if (_data == null)
            return "Unknown";
        
        var lowestPrice = GetLowestPrice();
        var highestPrice = GetHighestPrice();
        
        if (_data.OurPrice < lowestPrice)
            return "Lowest 🏆";
        if (_data.OurPrice > highestPrice)
            return "Highest ⚠️";
        return "Middle Range";
    }

    private string GetPositionCssClass()
    {
        if (_data == null)
            return string.Empty;
        
        var lowestPrice = GetLowestPrice();
        var highestPrice = GetHighestPrice();
        
        if (_data.OurPrice < lowestPrice)
            return "position-lowest";
        if (_data.OurPrice > highestPrice)
            return "position-highest";
        return "position-middle";
    }
}
