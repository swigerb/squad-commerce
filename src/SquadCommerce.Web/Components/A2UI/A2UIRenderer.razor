@using SquadCommerce.Contracts.A2UI

<div class="a2ui-renderer">
    @if (Payload == null)
    {
        <p class="text-muted">No data to display</p>
    }
    else
    {
        @switch (Payload.RenderAs)
        {
            case "RetailStockHeatmap":
                <ProtocolBadge Protocol="MCP" />
                <RetailStockHeatmap Payload="Payload" />
                break;
            case "PricingImpactChart":
                <ProtocolBadge Protocol="MCP" />
                <PricingImpactChart Payload="Payload" />
                break;
            case "MarketComparisonGrid":
                <ProtocolBadge Protocol="A2A" />
                <MarketComparisonGrid Payload="Payload" />
                break;
            case "DecisionAuditTrail":
                <ProtocolBadge Protocol="A2UI" />
                <DecisionAuditTrail Payload="Payload" />
                break;
            case "AgentPipelineVisualizer":
                <ProtocolBadge Protocol="AGUI" />
                <AgentPipelineVisualizer Payload="Payload" />
                break;
            case "InsightCard":
                <ProtocolBadge Protocol="A2UI" />
                <InsightCardRenderer Payload="Payload" />
                break;
            case "SocialSentimentGraph":
                <ProtocolBadge Protocol="MCP" />
                <SocialSentimentGraph Payload="Payload" />
                break;
            case "CampaignPreview":
                <ProtocolBadge Protocol="A2UI" />
                <CampaignPreview Payload="Payload" />
                break;
            case "ReroutingMap":
                <ProtocolBadge Protocol="A2A" />
                <ReroutingMap Payload="Payload" />
                break;
            case "SupplierRiskMatrix":
                <ProtocolBadge Protocol="A2A" />
                <SupplierRiskMatrix Payload="Payload" />
                break;
            case "InteractiveFloorplan":
                <ProtocolBadge Protocol="HITL" />
                <InteractiveFloorplan Payload="Payload" />
                break;
            default:
                <div class="alert alert-warning" role="alert">
                    <strong>Unknown A2UI component:</strong> @Payload.RenderAs
                </div>
                break;
        }
    }
</div>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }
}
