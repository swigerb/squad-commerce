@using SquadCommerce.Contracts.A2UI
@using System.Text.Json

<div class="retail-stock-heatmap" role="region" aria-label="Retail Stock Heatmap">
    <div class="component-header">
        <h3>📦 Retail Stock Levels</h3>
        @if (_data != null)
        {
            <div class="timestamp">
                <span class="timestamp-label">SKU:</span>
                <span class="timestamp-value">@_data.Sku</span>
                <span class="timestamp-label ms-3">Generated:</span>
                <span class="timestamp-value">@_data.Timestamp.ToString("g")</span>
            </div>
        }
    </div>

    @if (_data?.Stores != null && _data.Stores.Any())
    {
        <div class="heatmap-container">
            <table class="table table-bordered heatmap-table" aria-label="Inventory levels by store">
                <thead>
                    <tr>
                        <th scope="col" class="store-col sortable" @onclick="ToggleSort">
                            Store @GetSortIndicator()
                        </th>
                        <th scope="col" class="numeric-col">Units on Hand</th>
                        <th scope="col" class="numeric-col">Reorder Point</th>
                        <th scope="col" class="status-col">Stock Status</th>
                        <th scope="col" class="percent-col">% of Target</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var store in GetSortedStores())
                    {
                        var percent = GetPercentOfTarget(store);
                        var cssClass = GetCellCssClass(percent);
                        <tr class="@cssClass">
                            <th scope="row">@store.StoreName</th>
                            <td class="numeric-col" aria-label="@store.UnitsOnHand units">@store.UnitsOnHand</td>
                            <td class="numeric-col" aria-label="@store.ReorderPoint reorder point">@store.ReorderPoint</td>
                            <td class="status-col">
                                <span class="status-badge status-@store.StockStatus.ToLowerInvariant()">
                                    @GetStatusIcon(store.StockStatus) @store.StockStatus
                                </span>
                            </td>
                            <td class="percent-col" aria-label="@percent percent of target">
                                <div class="percent-bar-container">
                                    <div class="percent-bar" style="width: @(Math.Min(percent, 100))%"></div>
                                    <span class="percent-text">@percent%</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="heatmap-legend" role="img" aria-label="Heatmap color legend">
                <span class="legend-item">
                    <span class="legend-color bg-danger"></span> Critical (&lt; 10% of target)
                </span>
                <span class="legend-item">
                    <span class="legend-color bg-warning"></span> Low (10-30% of target)
                </span>
                <span class="legend-item">
                    <span class="legend-color bg-success"></span> Good (≥ 30% of target)
                </span>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">No inventory data available</div>
    }
</div>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }

    private RetailStockHeatmapData? _data;
    private bool _sortAscending = true;

    protected override void OnParametersSet()
    {
        if (Payload?.Data != null)
        {
            if (Payload.Data is JsonElement jsonElement)
            {
                _data = JsonSerializer.Deserialize<RetailStockHeatmapData>(
                    jsonElement.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else if (Payload.Data is RetailStockHeatmapData typedData)
            {
                _data = typedData;
            }
        }
    }

    private IEnumerable<StoreStockLevel> GetSortedStores()
    {
        if (_data?.Stores == null)
            return Enumerable.Empty<StoreStockLevel>();

        return _sortAscending
            ? _data.Stores.OrderBy(s => s.StoreName)
            : _data.Stores.OrderByDescending(s => s.StoreName);
    }

    private void ToggleSort()
    {
        _sortAscending = !_sortAscending;
    }

    private string GetSortIndicator() => _sortAscending ? "↑" : "↓";

    private int GetPercentOfTarget(StoreStockLevel store)
    {
        if (store.ReorderPoint == 0)
            return 0;
        return (int)((store.UnitsOnHand / (double)store.ReorderPoint) * 100);
    }

    private string GetCellCssClass(int percent)
    {
        if (percent < 10) return "row-critical";
        if (percent < 30) return "row-low";
        return "row-good";
    }

    private string GetStatusIcon(string status) => status.ToLowerInvariant() switch
    {
        "critical" => "🔴",
        "low" => "🟡",
        "adequate" => "🟢",
        "overstocked" => "🔵",
        _ => "⚪"
    };
}
