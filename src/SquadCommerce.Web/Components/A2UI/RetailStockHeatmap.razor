@using SquadCommerce.Contracts.A2UI
@using System.Text.Json

<div class="heatmap-wrapper" role="region" aria-label="Retail Stock Heatmap">
    @if (_data != null)
    {
        <div class="heatmap-title-bar">
            <h3 class="heatmap-title">📦 Inventory Heatmap — <span class="sku-accent">@_data.Sku</span></h3>
            <span class="heatmap-ts">@_data.Timestamp.ToString("g")</span>
        </div>

        @if (_data.Stores != null && _data.Stores.Any())
        {
            <div class="store-grid">
                @{ var idx = 0; }
                @foreach (var store in GetSortedStores())
                {
                    var fillPct = GetFillPercent(store);
                    var sClass = GetStoreStatusClass(store);
                    var isCritical = store.StockStatus.Equals("Critical", StringComparison.OrdinalIgnoreCase);
                    <div class="store-card @sClass @(isCritical ? "critical-pulse" : "")"
                         style="animation-delay: @(idx * 0.06)s"
                         role="article" aria-label="@store.StoreName: @store.UnitsOnHand units">
                        <div class="store-name-row">
                            <span class="loc-icon">📍</span>
                            <span>@store.StoreName</span>
                        </div>
                        <div class="unit-display">
                            <span class="unit-number">@store.UnitsOnHand</span>
                            <span class="unit-label">units</span>
                        </div>
                        <div class="fill-track">
                            <div class="fill-progress" style="width: @(Math.Min(fillPct, 100))%"></div>
                            <div class="reorder-marker" style="left: 33.3%" title="Reorder Point: @store.ReorderPoint"></div>
                        </div>
                        <div class="card-footer-row">
                            <span class="status-text">@GetStatusIndicator(store.StockStatus)</span>
                            <span class="rop-badge">ROP @store.ReorderPoint</span>
                        </div>
                    </div>
                    idx++;
                }
            </div>

            <div class="heatmap-footer">
                <div class="footer-stat">
                    <span class="footer-val">@GetTotalUnits().ToString("N0")</span>
                    <span class="footer-label">Total Units</span>
                </div>
                <div class="footer-stat footer-danger">
                    <span class="footer-val">@GetStoresAtRisk()</span>
                    <span class="footer-label">Stores at Risk</span>
                </div>
                <div class="footer-stat">
                    <span class="footer-val">@GetAverageFill()%</span>
                    <span class="footer-label">Avg Fill</span>
                </div>
            </div>
        }
        else
        {
            <div class="no-data">No inventory data available</div>
        }
    }
    else
    {
        <div class="no-data">Loading inventory data…</div>
    }
</div>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }

    private RetailStockHeatmapData? _data;
    private bool _sortAscending = true;

    protected override void OnParametersSet()
    {
        if (Payload?.Data != null)
        {
            if (Payload.Data is JsonElement jsonElement)
            {
                _data = JsonSerializer.Deserialize<RetailStockHeatmapData>(
                    jsonElement.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else if (Payload.Data is RetailStockHeatmapData typedData)
            {
                _data = typedData;
            }
        }
    }

    private IEnumerable<StoreStockLevel> GetSortedStores()
    {
        if (_data?.Stores == null)
            return Enumerable.Empty<StoreStockLevel>();

        return _sortAscending
            ? _data.Stores.OrderBy(s => s.StoreName)
            : _data.Stores.OrderByDescending(s => s.StoreName);
    }

    private int GetFillPercent(StoreStockLevel store)
    {
        if (store.ReorderPoint == 0) return 0;
        return (int)(store.UnitsOnHand / (store.ReorderPoint * 3.0) * 100);
    }

    private string GetStoreStatusClass(StoreStockLevel store) => store.StockStatus.ToLowerInvariant() switch
    {
        "critical" => "sc-critical",
        "low" => "sc-low",
        "adequate" => "sc-adequate",
        "overstocked" => "sc-overstocked",
        _ => "sc-adequate"
    };

    private string GetStatusIndicator(string status) => status.ToLowerInvariant() switch
    {
        "critical" => "🔴 Critical",
        "low" => "🟡 Low",
        "adequate" => "🟢 Adequate",
        "overstocked" => "🔵 Overstocked",
        _ => "⚪ Unknown"
    };

    private int GetTotalUnits() => _data?.Stores?.Sum(s => s.UnitsOnHand) ?? 0;

    private int GetStoresAtRisk() => _data?.Stores?.Count(s =>
        s.StockStatus.Equals("Critical", StringComparison.OrdinalIgnoreCase) ||
        s.StockStatus.Equals("Low", StringComparison.OrdinalIgnoreCase)) ?? 0;

    private int GetAverageFill()
    {
        if (_data?.Stores == null || !_data.Stores.Any()) return 0;
        return (int)_data.Stores.Average(s =>
            s.ReorderPoint == 0 ? 0 : s.UnitsOnHand / (s.ReorderPoint * 3.0) * 100);
    }
}
