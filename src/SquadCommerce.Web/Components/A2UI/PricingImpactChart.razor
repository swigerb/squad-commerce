@using SquadCommerce.Contracts.A2UI
@using System.Text.Json

<div class="pricing-wrapper" role="region" aria-label="Pricing Impact Analysis">
    @if (_data != null)
    {
        <div class="pricing-title-bar">
            <h3 class="pricing-title">💰 Pricing Impact Analysis — <span class="sku-accent">@_data.Sku</span></h3>
            <span class="pricing-ts">@_data.Timestamp.ToString("g")</span>
        </div>

        @if (_data.Scenarios != null && _data.Scenarios.Any())
        {
            <div class="price-hero">
                <div class="price-current">
                    <span class="price-label">Current</span>
                    <span class="price-amount">@_data.CurrentPrice.ToString("C")</span>
                </div>
                <div class="price-arrow-container">
                    <div class="price-arrow">→</div>
                    <div class="price-delta @GetPriceDeltaCssClass()">
                        @GetPriceDelta().ToString("+0.0%;-0.0%;0.0%")
                    </div>
                </div>
                <div class="price-proposed">
                    <span class="price-label">Proposed</span>
                    <span class="price-amount">@_data.ProposedPrice.ToString("C")</span>
                </div>
            </div>

            <div class="scenarios-scroll">
                @{ var sIdx = 0; }
                @foreach (var scenario in _data.Scenarios)
                {
                    var isRec = IsRecommended(scenario);
                    var marginPct = scenario.EstimatedMargin * 100;
                    var marginDelta = scenario.EstimatedMargin - GetBaselineMargin();
                    <div class="scenario-card @(isRec ? "recommended" : "")"
                         style="animation-delay: @(sIdx * 0.1)s"
                         role="article" aria-label="Scenario: @scenario.ScenarioName">
                        @if (isRec)
                        {
                            <div class="rec-badge">⭐ Recommended</div>
                        }
                        <div class="scenario-name">@scenario.ScenarioName</div>
                        <div class="scenario-price-display">@scenario.Price.ToString("C")</div>

                        <div class="metric-block">
                            <div class="metric-header">
                                <span class="metric-title">Margin</span>
                                <span class="metric-val @GetMarginColorClass(scenario.EstimatedMargin)">@marginPct.ToString("0.0")%</span>
                            </div>
                            <div class="margin-bar-track">
                                <div class="margin-bar-fill @GetMarginColorClass(scenario.EstimatedMargin)"
                                     style="width: @(Math.Min(marginPct * 2, 100))%"></div>
                            </div>
                            @if (marginDelta != 0)
                            {
                                <span class="margin-delta @(marginDelta > 0 ? "delta-pos" : "delta-neg")">
                                    @(marginDelta > 0 ? "▲" : "▼") @Math.Abs(marginDelta * 100).ToString("0.0")pp
                                </span>
                            }
                        </div>

                        <div class="metric-block">
                            <div class="metric-header">
                                <span class="metric-title">Revenue</span>
                                <span class="metric-val revenue-val">@scenario.EstimatedRevenue.ToString("C0")</span>
                            </div>
                        </div>

                        <div class="metric-block">
                            <div class="metric-header">
                                <span class="metric-title">Units Sold</span>
                                <span class="metric-val units-val">@scenario.ProjectedUnitsSold.ToString("N0")</span>
                            </div>
                        </div>

                        <button class="select-btn" @onclick="() => SelectScenario(scenario)"
                                aria-label="Select @scenario.ScenarioName">
                            Select Scenario
                        </button>
                    </div>
                    sIdx++;
                }
            </div>

            <div class="pricing-summary">
                <div class="summary-insight">
                    <div class="insight-header">
                        <span class="insight-icon">🤖</span>
                        <span class="insight-title">Recommended Action</span>
                        <span class="confidence-badge">High Confidence</span>
                    </div>
                    <p class="insight-text">
                        Based on margin analysis and projected volume,
                        <strong>@GetRecommendedScenarioName()</strong> offers the best balance
                        of profitability and competitiveness.
                    </p>
                </div>
            </div>
        }
        else
        {
            <div class="no-data">No pricing scenarios available</div>
        }
    }
    else
    {
        <div class="no-data">Loading pricing data…</div>
    }
</div>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }

    [Parameter]
    public EventCallback<PriceScenario> OnScenarioSelected { get; set; }

    private PricingImpactChartData? _data;

    protected override void OnParametersSet()
    {
        if (Payload?.Data != null)
        {
            if (Payload.Data is JsonElement jsonElement)
            {
                _data = JsonSerializer.Deserialize<PricingImpactChartData>(
                    jsonElement.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else if (Payload.Data is PricingImpactChartData typedData)
            {
                _data = typedData;
            }
        }
    }

    private decimal GetBaselineMargin()
    {
        if (_data == null || _data.CurrentPrice == 0) return 0;
        return _data.Scenarios?.FirstOrDefault()?.EstimatedMargin ?? 0;
    }

    private async Task SelectScenario(PriceScenario scenario)
    {
        if (OnScenarioSelected.HasDelegate)
            await OnScenarioSelected.InvokeAsync(scenario);
    }

    private decimal GetPriceDelta()
    {
        if (_data == null || _data.CurrentPrice == 0) return 0;
        return (_data.ProposedPrice - _data.CurrentPrice) / _data.CurrentPrice;
    }

    private string GetPriceDeltaCssClass()
    {
        var delta = GetPriceDelta();
        if (delta < 0) return "delta-neg";
        if (delta > 0) return "delta-pos";
        return "delta-neutral";
    }

    private string GetMarginColorClass(decimal margin)
    {
        if (margin < 0.10m) return "color-danger";
        if (margin < 0.20m) return "color-warn";
        return "color-success";
    }

    private bool IsRecommended(PriceScenario scenario)
    {
        if (_data?.Scenarios == null || !_data.Scenarios.Any()) return false;
        var best = _data.Scenarios
            .OrderByDescending(s => s.EstimatedRevenue)
            .ThenByDescending(s => s.EstimatedMargin)
            .First();
        return scenario.ScenarioName == best.ScenarioName;
    }

    private string GetRecommendedScenarioName()
    {
        if (_data?.Scenarios == null || !_data.Scenarios.Any()) return "N/A";
        return _data.Scenarios
            .OrderByDescending(s => s.EstimatedRevenue)
            .ThenByDescending(s => s.EstimatedMargin)
            .First().ScenarioName;
    }
}
