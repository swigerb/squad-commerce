@using SquadCommerce.Contracts.A2UI
@using System.Text.Json

<div class="pricing-impact-chart" role="region" aria-label="Pricing Impact Analysis">
    <div class="component-header">
        <h3>💰 Pricing Impact Analysis</h3>
        @if (_data != null)
        {
            <div class="timestamp">
                <span class="timestamp-label">SKU:</span>
                <span class="timestamp-value">@_data.Sku</span>
                <span class="timestamp-label ms-3">Generated:</span>
                <span class="timestamp-value">@_data.Timestamp.ToString("g")</span>
            </div>
        }
    </div>

    @if (_data?.Scenarios != null && _data.Scenarios.Any())
    {
        <div class="price-comparison-section mb-4">
            <div class="price-flow-header">
                <div class="price-box current">
                    <div class="price-label">Current Price</div>
                    <div class="price-value">@_data.CurrentPrice.ToString("C")</div>
                </div>
                <div class="price-arrow">→</div>
                <div class="price-box proposed">
                    <div class="price-label">Proposed Price</div>
                    <div class="price-value">@_data.ProposedPrice.ToString("C")</div>
                </div>
                <div class="price-delta @GetPriceDeltaCssClass()">
                    @GetPriceDelta().ToString("+0.0%;-0.0%;0.0%")
                </div>
            </div>
        </div>

        <div class="scenarios-grid">
            @foreach (var scenario in _data.Scenarios)
            {
                var marginPercent = scenario.EstimatedMargin * 100;
                <div class="scenario-card" role="article" aria-label="Scenario: @scenario.ScenarioName">
                    <div class="scenario-header">
                        <h4 class="scenario-name">@scenario.ScenarioName</h4>
                        <div class="scenario-price">@scenario.Price.ToString("C")</div>
                    </div>
                    <div class="scenario-body">
                        <div class="metric-row">
                            <span class="metric-label">💹 Estimated Margin:</span>
                            <span class="metric-value margin @GetMarginCssClass(scenario.EstimatedMargin)">
                                @marginPercent.ToString("0.0")%
                            </span>
                        </div>
                        <div class="metric-row">
                            <span class="metric-label">💵 Estimated Revenue:</span>
                            <span class="metric-value revenue @GetRevenueCssClass(scenario.EstimatedRevenue)">
                                @scenario.EstimatedRevenue.ToString("C0")
                            </span>
                        </div>
                        <div class="metric-row">
                            <span class="metric-label">📦 Projected Units Sold:</span>
                            <span class="metric-value units">
                                @scenario.ProjectedUnitsSold.ToString("N0")
                            </span>
                        </div>
                    </div>
                    <div class="scenario-footer">
                        <button class="btn btn-sm btn-outline-primary" 
                                @onclick="() => SelectScenario(scenario)"
                                aria-label="Select @scenario.ScenarioName">
                            Select
                        </button>
                    </div>
                </div>
            }
        </div>

        <div class="approval-section mt-4">
            <div class="alert alert-info">
                <strong>💡 Tip:</strong> Review each scenario's margin and revenue impact before making a decision.
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">No pricing scenarios available</div>
    }
</div>

@code {
    [Parameter]
    public A2UIPayload? Payload { get; set; }

    [Parameter]
    public EventCallback<PriceScenario> OnScenarioSelected { get; set; }

    private PricingImpactChartData? _data;

    protected override void OnParametersSet()
    {
        if (Payload?.Data != null)
        {
            if (Payload.Data is JsonElement jsonElement)
            {
                _data = JsonSerializer.Deserialize<PricingImpactChartData>(
                    jsonElement.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else if (Payload.Data is PricingImpactChartData typedData)
            {
                _data = typedData;
            }
        }
    }

    private async Task SelectScenario(PriceScenario scenario)
    {
        if (OnScenarioSelected.HasDelegate)
        {
            await OnScenarioSelected.InvokeAsync(scenario);
        }
    }

    private decimal GetPriceDelta()
    {
        if (_data == null || _data.CurrentPrice == 0)
            return 0;
        return (_data.ProposedPrice - _data.CurrentPrice) / _data.CurrentPrice;
    }

    private string GetPriceDeltaCssClass()
    {
        var delta = GetPriceDelta();
        if (delta < 0) return "delta-negative";
        if (delta > 0) return "delta-positive";
        return "delta-neutral";
    }

    private string GetMarginCssClass(decimal margin)
    {
        if (margin < 0.10m) return "text-danger";
        if (margin < 0.20m) return "text-warning";
        return "text-success";
    }

    private string GetRevenueCssClass(decimal revenue)
    {
        if (revenue < 0) return "text-danger";
        if (revenue > 0) return "text-success";
        return "text-muted";
    }
}
