@if (IsVisible)
{
    <div class="shortcut-overlay" @onclick="Close" @onkeydown="HandleKeyDown" tabindex="-1"
         role="dialog" aria-modal="true" aria-label="Keyboard shortcuts">
        <div class="shortcut-modal" @onclick:stopPropagation="true">
            <div class="shortcut-header">
                <span class="shortcut-title">⌨️ Keyboard Shortcuts</span>
                <button class="shortcut-close" @onclick="Close" aria-label="Close">✕</button>
            </div>
            <div class="shortcut-body">
                <div class="shortcut-section">
                    <h3>Navigation</h3>
                    <div class="shortcut-row"><kbd>1</kbd><span>Focus Chat panel</span></div>
                    <div class="shortcut-row"><kbd>2</kbd><span>Focus Dashboard panel</span></div>
                    <div class="shortcut-row"><kbd>3</kbd><span>Focus Pipeline panel</span></div>
                    <div class="shortcut-row"><kbd>4</kbd><span>Focus Agent Fleet panel</span></div>
                </div>
                <div class="shortcut-section">
                    <h3>Actions</h3>
                    <div class="shortcut-row"><kbd>/</kbd><span>Focus chat input</span></div>
                    <div class="shortcut-row"><kbd>Ctrl+K</kbd><span>Open command palette</span></div>
                    <div class="shortcut-row"><kbd>Esc</kbd><span>Close modal / palette</span></div>
                    <div class="shortcut-row"><kbd>?</kbd><span>Show this help</span></div>
                </div>
            </div>
            <div class="shortcut-footer">
                Press <kbd>Esc</kbd> or <kbd>?</kbd> to close
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" || e.Key == "?")
        {
            await Close();
        }
    }
}
