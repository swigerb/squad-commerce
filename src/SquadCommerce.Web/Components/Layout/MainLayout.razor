@inherits LayoutComponentBase

<div class="app-layout">
    <header class="app-header">
        <div class="header-brand">
            <h1>🛒 Squad Commerce</h1>
            <span class="header-subtitle">AI-Powered Retail Management</span>
        </div>
        <AgentStatusBar />
    </header>

    <div class="app-content">
        <aside class="sidebar-left">
            <div class="sidebar-header">
                <h2>💬 Conversation</h2>
            </div>
            <AgentChat />
        </aside>

        <main class="main-content">
            <div class="content-header">
                <h2>📊 Analysis Dashboard</h2>
            </div>
            <article class="content-body">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    <div class="blazor-error-content">
        <span class="blazor-error-icon">⚠️</span>
        <span class="blazor-error-text">An unhandled error has occurred.</span>
        <button class="blazor-error-reload" onclick="location.reload()">Reload</button>
        <button class="blazor-error-dismiss" onclick="document.getElementById('blazor-error-ui').style.display='none'">Dismiss</button>
    </div>
</div>
